{
    "interface": "auto",
    "network": {
        "auto_detect": true,
        "scan_target": "gateway"
    },
    "log_file": "logs/alerts.json",
    "status_file": "logs/status.json",
    "alert_cooldown_seconds": 10,
    "traffic_monitor": {
        "enabled": true,
        "log_file": "logs/traffic.json",
        "max_records": 20
    },
    "suricata": {
        "enabled": true,
        "eve_log_file": "logs/suricata/eve.json",
        "local_rules_file": "suricata/local.rules",
        "max_alerts": 100
    },
    "active_response": {
        "enabled": true,
        "auto_block_enabled": false,
        "block_minutes": 10,
        "block_alert_types": [
            "ICMP_FLOOD",
            "FUERZA_BRUTA_SSH"
        ],
        "windows_firewall_rule_prefix": "TrafficWatch IDS Auto Block"
    },
    "rules": {
        "port_scan": {
            "enabled": true,
            "time_window_seconds": 10,
            "unique_ports_threshold": 10
        },
        "icmp_flood": {
            "enabled": true,
            "time_window_seconds": 5,
            "packet_threshold": 20
        },
        "syn_flood": {
            "enabled": true,
            "time_window_seconds": 5,
            "packet_threshold": 30
        },
        "brute_force": {
            "enabled": true,
            "time_window_seconds": 30,
            "attempt_threshold": 8,
            "ports": {
                "FTP": 21,
                "SSH": 22,
                "TELNET": 23,
                "RDP": 3389
            }
        },
        "connection_frequency": {
            "enabled": true,
            "time_window_seconds": 10,
            "packet_threshold": 100
        },
        "suspicious_ports": {
            "enabled": true,
            "ports": [
                21,
                22,
                23,
                3389,
                4444,
                5900
            ]
        },
        "rare_ports": {
            "enabled": true,
            "ports": [
                1337,
                2323,
                31337,
                5555,
                6667,
                9001
            ]
        }
    }
}
